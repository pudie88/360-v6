#!/bin/bash
# diy-script.sh - 适配 GitHub Actions + 官方 OpenWrt
# 工作目录：已 cd 到 openwrt/

set -e

# ✅ 关键：禁用 git 交互式认证提示，避免 "could not read Username" 错误
export GIT_TERMINAL_PROMPT=0
export GIT_ASKPASS=/bin/echo

cd "$GITHUB_WORKSPACE/openwrt"

# 通用克隆函数（带重试 + 静默认证）
clone_with_retry() {
    local repo_url="$1"
    local target_dir="$2"
    local max_retries=3
    local retry_count=0
    
    while [ $retry_count -lt $max_retries ]; do
        echo ">>> 克隆 $target_dir (尝试 $((retry_count+1))/$max_retries)"
        
        if git clone --depth 1 "$repo_url" "$target_dir" 2>&1; then
            echo "✅ 克隆成功: $target_dir"
            return 0
        fi
        
        retry_count=$((retry_count+1))
        if [ $retry_count -lt $max_retries ]; then
            echo "⚠️ 克隆失败，5 秒后重试..."
            sleep 5
            # 清理失败的部分目录
            rm -rf "$target_dir" 2>/dev/null || true
        fi
    done
    
    echo "❌ 克隆失败: $repo_url"
    return 1
}

# ======================================================
# PassWall
# ======================================================
echo ">>> 克隆 PassWall"
if [ ! -d "package/luci-app-passwall" ]; then
    clone_with_retry \
        "https://github.com/xiaorouji/openwrt-passwall" \
        "package/luci-app-passwall" || {
        echo "::warning::PassWall 克隆失败，尝试备用源..."
        # 备用源（如果主源失败）
        git clone --depth 1 \
            https://hub.fastgit.xyz/xiaorouji/openwrt-passwall \
            package/luci-app-passwall 2>/dev/null || true
    }
fi

# ======================================================
# AdGuardHome
# ======================================================
echo ">>> 克隆 AdGuardHome"
if [ ! -d "package/luci-app-adguardhome" ]; then
    clone_with_retry \
        "https://github.com/rufengsuixing/luci-app-adguardhome" \
        "package/luci-app-adguardhome" || true
fi

# ======================================================
# Argon 主题（替换 lean 自带的旧版本）
# ======================================================
echo ">>> 克隆 Argon 主题"
rm -rf package/lean/luci-theme-argon 2>/dev/null || true

if [ ! -d "package/luci-theme-argon" ]; then
    clone_with_retry \
        "https://github.com/jerrykuku/luci-theme-argon" \
        "package/luci-theme-argon" || true
fi

if [ ! -d "package/luci-app-argon-config" ]; then
    clone_with_retry \
        "https://github.com/jerrykuku/luci-app-argon-config" \
        "package/luci-app-argon-config" || true
fi

# ======================================================
# 可选插件（按需启用，避免体积过大）
# ======================================================

# MosDNS v5（如果 .config 中启用才克隆）
if grep -q "CONFIG_PACKAGE_luci-app-mosdns=y" .config 2>/dev/null; then
    echo ">>> 克隆 MosDNS v5"
    if [ ! -d "package/mosdns" ]; then
        clone_with_retry \
            "https://github.com/sbwml/luci-app-mosdns" \
            "package/mosdns" || true
    fi
fi

# v2ray-geodata（体积大，按需克隆）
if grep -q "CONFIG_PACKAGE_v2ray-geodata=y" .config 2>/dev/null; then
    echo ">>> 克隆 v2ray-geodata"
    if [ ! -d "package/v2ray-geodata" ]; then
        clone_with_retry \
            "https://github.com/sbwml/v2ray-geodata" \
            "package/v2ray-geodata" || true
    fi
fi

# ======================================================
# 明确跳过（避免冲突/体积过大）
# ======================================================
# ❌ OpenClash：与 PassWall 功能重叠 + 体积大 + 编译慢
# ❌ ZeroTier：如需远程访问建议用 Tailscale（更轻量）

echo ">>> DIY 脚本执行完成 ✅"
