# files/etc/config/network
# 此文件是编译时默认值，uci-defaults 脚本首次启动时会按实际内核接口覆盖。
# LAN IP 统一为 192.168.1.1，与脚本一致。
# WAN 占位用 eth4（新内核默认），旧内核由脚本自动修正。

config interface 'loopback'
    option device 'lo'
    option proto 'static'
    option ipaddr '127.0.0.1'
    option netmask '255.0.0.0'

config globals 'globals'
    option ula_prefix 'auto'

config device 'lan_dev'
    option name 'br-lan'
    option type 'bridge'
    list ports 'eth0'
    list ports 'eth1'
    list ports 'eth2'
    list ports 'eth3'

config interface 'lan'
    option device 'br-lan'
    option proto 'static'
    option ipaddr '192.168.1.1'
    option netmask '255.255.255.0'
    option ip6assign '60'

config interface 'wan'
    option device 'eth4'
    option proto 'dhcp'

config interface 'wan6'
    option device 'eth4'
    option proto 'dhcpv6'
