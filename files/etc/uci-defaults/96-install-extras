#!/bin/sh
# 96-install-extras [v11.3]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# v11.3 修复（基于 v11.2 代码审查）：
#   1. Docker 版本列表更新为实测可用的新版本（28.x 系列）
#   2. AGH init.d：无配置文件时不传 --config，进入 setup 模式
#   3. 360v6-uninstall：补充 rmdir 清理空目录

_STATE_DIR="/etc/install-state"
mkdir -p "$_STATE_DIR" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1

# ══════════════════════════════════════════════════════════════
# 模块 0：360v6-status
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

_svc_check() {
    __svc_cmd="$1"; __svc_name="$2"
    __si=1
    while [ "$__si" -le 3 ]; do
        eval "$__svc_cmd" >/dev/null 2>&1 && {
            case "$__svc_name" in
                Docker)
                    __ver=$(docker version --format '{{.Server.Version}}' 2>/dev/null)
                    echo "[OK] Docker      : ${__ver:-运行中}"
                    return ;;
                AdGuardHome)
                    __ver=$(AdGuardHome --version 2>&1 | head -1 \
                        | grep -oE 'v[0-9.]+' || echo "")
                    echo "[OK] AdGuardHome : ${__ver:-运行中}"
                    return ;;
            esac
        }
        sleep 1; __si=$((__si + 1))
    done
    echo "[--] ${__svc_name}      : 未启动"
}

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

_ver=$(head -3 /usr/lib/install-extras/run.sh 2>/dev/null \
    | grep -oE 'v[0-9][0-9.]*' | head -1)
[ -n "$_ver" ] && echo "版本  : $_ver"

if [ -f /etc/install-extras-done ]; then
    _t=$(cat /etc/install-extras-done 2>/dev/null)
    echo "[OK] 基础环境：已完成${_t:+ ($_t)}"
else
    echo "[..] 基础环境：待触发"
fi
_p1=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "$_p1" -gt 0 ] && echo "     失败次数: $_p1/3"

if [ -f /etc/install-usb-done ]; then
    _t=$(cat /etc/install-usb-done 2>/dev/null)
    echo "[OK] 重型应用：已完成${_t:+ ($_t)}"
else
    echo "[..] 重型应用：待 U 盘"
fi
_p2=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
if [ "$_p2" -gt 0 ]; then
    echo "     失败次数: $_p2/3"
    _dldir=$(cat /etc/install-usb-mount 2>/dev/null)
    if [ -n "$_dldir" ] && [ -d "$_dldir/.downloads" ]; then
        for _f in "$_dldir/.downloads"/*.tgz "$_dldir/.downloads"/*.tar.gz; do
            [ -f "$_f" ] || continue
            tar -tzf "$_f" >/dev/null 2>&1 \
                || echo "     ⚠ 损坏缓存: $(basename "$_f")（重跑时将自动清理）"
        done
    fi
fi

echo ""
df -h /overlay 2>/dev/null \
    | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null \
    | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=""
for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    _is_mounted "$_mp" && { echo "USB   : $_mp (已挂载)"; _USB="$_mp"; break; }
done
[ -z "$_USB" ] && echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] \
    && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
grep -q zram     /proc/swaps 2>/dev/null && echo "Swap  : zram 已激活"
echo ""

_svc_check "docker info" "Docker"
_svc_check "pgrep -x AdGuardHome" "AdGuardHome"

echo ""
echo "重跑基础: rm -f /etc/install-extras-done $_SD/phase1-failures && /usr/lib/install-extras/run.sh"
echo "重跑重型: rm -f /etc/install-usb-done && /usr/lib/install-extras/install-usb.sh --force"
echo "  （--force 自动清零失败计数，无需手动删 phase2-failures）"
echo "健康检查: 360v6-health [--fix]"
echo "卸载    : 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 A：install-usb.sh（Phase 2）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

# Fix #1：更新为实测可用的新版本（降序，优先下载新版）
# 来源：https://download.docker.com/linux/static/stable/aarch64/
_DOCKER_VERS="28.1.0 28.0.4 27.5.1 26.1.4 25.0.5 24.0.7"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() {
    __lm="[$(date '+%H:%M:%S')] $1"
    echo "$__lm"
    echo "$__lm" | logger -t "$_LT"
}
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

mkdir -p "$_SD"

# ── 参数解析 ──────────────────────────────────────────────────────
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# ── 自愈模式 ──────────────────────────────────────────────────────
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __sf=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__sf:-0}" -ge 3 ] && exit 0
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        kill -0 "$__lp" 2>/dev/null && exit 0
        log "清理残留锁 (旧pid=$__lp)"; rm -f "$_LOCK"
    fi
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && {
            log "自愈触发: $_mp"
            exec /usr/lib/install-extras/install-usb.sh "$_mp"
        }
    done
    exit 0
fi

# ── 幂等保护 ──────────────────────────────────────────────────────
[ -f "$_DONE" ] && { log "已完成，跳过"; exit 0; }

# ── 先设 trap，再检查锁，最后写锁 ────────────────────────────────
__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    printf '%s' "$__dns_old" > /etc/resolv.conf
    /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
}
trap 'rm -f "$_LOCK"; _dns_restore' EXIT INT TERM

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    log "清理残留锁 (旧pid=$__lp)"; rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

# ── 失败计数 ──────────────────────────────────────────────────────
if [ "$__force" -eq 1 ]; then
    rm -f "$_SD/phase2-failures"; __fail=0
    log "--force 模式：失败计数已清零"
else
    __fail=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__fail:-0}" -ge 3 ] && {
        log "失败次数过多（$__fail/3），停止自动重试"
        log "手动修复: rm -f /etc/install-usb-done && $0 --force"
        exit 1
    }
fi

# ── 挂载点检测 ────────────────────────────────────────────────────
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
if [ -z "$_USB" ]; then
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { _USB="$_mp"; break; }
    done
fi
[ -z "$_USB" ] && \
    _USB=$(awk '/^\/dev\/sd[a-z][0-9][0-9]* /{print $2; exit}' \
           /proc/mounts 2>/dev/null)
if [ -z "$_USB" ]; then
    log "未找到 U 盘挂载点，退出"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi
echo "$_USB" > "$_MF"
log "重型应用部署启动 | U 盘: $_USB"

# ── 空间预检（U 盘 >= 1GB）───────────────────────────────────────
__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__usb_free:-0}" -lt 1048576 ]; then
    log "U 盘可用空间不足（${__usb_free}KB < 1GB），退出"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

# ── U 盘写入健康检查 ──────────────────────────────────────────────
__wtest="$_USB/.write-test-$$"
if ! echo "ok" > "$__wtest" 2>/dev/null; then
    log "U 盘写入失败（只读？文件系统错误？）"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi
rm -f "$__wtest"

# ── DNS 注入 ──────────────────────────────────────────────────────
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

# ── I/O 调度优化 ──────────────────────────────────────────────────
__udev=$(grep " $_USB " /proc/mounts 2>/dev/null | head -1 \
    | awk '{print $1}' | sed 's|/dev/||;s|[0-9]*$||')
__sched="/sys/block/${__udev}/queue/scheduler"
if [ -n "$__udev" ] && [ -f "$__sched" ]; then
    grep -q "mq-deadline" "$__sched" 2>/dev/null \
        && echo "mq-deadline" > "$__sched" 2>/dev/null \
        || echo "deadline"    > "$__sched" 2>/dev/null
    log "I/O 调度器: $(grep -oE '\[[^]]+\]' "$__sched" 2>/dev/null | tr -d '[]')"
fi
echo "10"    > /proc/sys/vm/swappiness      2>/dev/null
echo "16384" > /proc/sys/vm/min_free_kbytes 2>/dev/null
log "内存参数: swappiness=10 min_free_kbytes=16MB"

# ── Swap（原子写入 + fstab 持久化）───────────────────────────────
__swapfile="$_USB/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 256MB swapfile（原子写入）..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=256 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile"
            sync; chmod 600 "$__swapfile"
            mkswap "$__swapfile" >/dev/null 2>&1
            log "swapfile 已创建"
        else
            rm -f "${__swapfile}.tmp"
            log "swapfile 创建失败（空间不足？）"
        fi
    fi
    if [ -f "$__swapfile" ]; then
        swapon "$__swapfile" 2>/dev/null && log "swapfile 已激活"
        grep -qF "$__swapfile" /etc/fstab 2>/dev/null \
            || echo "$__swapfile none swap sw 0 0" >> /etc/fstab
    fi
fi

# ── 下载函数（失败重试 3 次）─────────────────────────────────────
_download() {
    __dl_url="$1"; __dl_out="$2"; __dl_desc="$3"
    __dl_i=1
    while [ "$__dl_i" -le 3 ]; do
        log "下载 $__dl_desc（$__dl_i/3）..."
        wget -q --timeout=120 --tries=1 \
             -O "${__dl_out}.tmp" "$__dl_url" 2>/dev/null \
            && mv "${__dl_out}.tmp" "$__dl_out" \
            && { log "下载完成: $__dl_desc"; return 0; }
        rm -f "${__dl_out}.tmp"
        log "下载失败: $__dl_desc ($__dl_i/3)"
        __dl_i=$((__dl_i + 1))
        sleep 5
    done
    log "下载彻底失败: $__dl_desc"
    return 1
}

__flash_free=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
__skip_luci=0
[ "${__flash_free:-99999}" -lt 25000 ] && __skip_luci=1 \
    && log "Flash <25MB，跳过 LuCI 插件"

__dl_dir="$_USB/.downloads"; mkdir -p "$__dl_dir"

# ══ Docker 部署 ════════════════════════════════════════════════════
_DOCKER_FAIL=0
log "--- Docker 部署开始 ---"

__fs_type=$(awk -v mp="$_USB" '$2==mp {print $3}' /proc/mounts 2>/dev/null)
case "$__fs_type" in
    ext[234]|f2fs) ;;
    *)
        log "Docker 需要 ext4/f2fs（当前: ${__fs_type:-未知}），overlay2 不兼容"
        log "建议: mkfs.ext4 格式化 U 盘后重试"
        _DOCKER_FAIL=1 ;;
esac

__docker_ver=""
__dtgz=""
__dbin="$_USB/docker-bin"
__ddata="$_USB/docker-data"

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    mkdir -p "$__dbin" "$__ddata" /etc/docker

    for _dv in $_DOCKER_VERS; do
        __dtgz_try="$__dl_dir/docker-${_dv}.tgz"
        if [ -f "$__dtgz_try" ]; then
            if tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
                log "使用缓存: docker-${_dv}.tgz"
                __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
            else
                log "缓存损坏，删除: docker-${_dv}.tgz"
                rm -f "$__dtgz_try"
            fi
        fi
        log "尝试 Docker ${_dv}..."
        if wget -q --timeout=120 --tries=1 \
                -O "${__dtgz_try}.tmp" \
                "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null \
            && mv "${__dtgz_try}.tmp" "$__dtgz_try" \
            && tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
            log "下载成功: Docker ${_dv}"
            __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
        fi
        rm -f "${__dtgz_try}.tmp" "$__dtgz_try"
        log "Docker ${_dv} 不可用，尝试下一版本"
    done

    if [ -z "$__docker_ver" ]; then
        log "所有 Docker 版本均下载失败，跳过"
        rm -f "$__dl_dir"/docker-*.tgz.tmp 2>/dev/null
        _DOCKER_FAIL=1
    fi
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    log "解压 Docker $__docker_ver..."
    tar -xzf "$__dtgz" -C "$__dbin" --strip-components=1 2>/dev/null
    if [ ! -f "$__dbin/dockerd" ]; then
        log "解压后未找到 dockerd，删除缓存"
        rm -f "$__dtgz"; _DOCKER_FAIL=1
    fi
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    for _b in docker dockerd docker-init docker-proxy containerd \
              containerd-shim-runc-v2 ctr runc; do
        [ -f "$__dbin/$_b" ] \
            && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null \
            && log "symlink: /usr/bin/$_b"
    done

    cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
DOCKEREOF
    log "daemon.json 已写入 | data-root=$__ddata"

    cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1
    grep -q "^[^ ]* /sys/fs/cgroup " /proc/mounts 2>/dev/null || {
        mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null \
            || mount -t cgroup none /sys/fs/cgroup 2>/dev/null || true
    }
    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" \
        --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() {
    docker stop $(docker ps -q 2>/dev/null) 2>/dev/null || true
    sleep 2
    pkill dockerd    2>/dev/null || true
    pkill containerd 2>/dev/null || true
}
DINITEOF
    chmod +x /etc/init.d/dockerd
    /etc/init.d/dockerd enable 2>/dev/null
    /etc/init.d/dockerd start  2>/dev/null
    __di=1
    while [ "$__di" -le 15 ]; do
        docker info >/dev/null 2>&1 && break
        sleep 2; __di=$((__di + 1))
    done
    docker info >/dev/null 2>&1 \
        && log "Docker $__docker_ver 已启动 | bin=$__dbin data=$__ddata" \
        || log "Docker 启动超时（服务已注册，重启后可用）"

    if [ "$__skip_luci" -eq 0 ]; then
        __lt=$(mktemp /tmp/apk.XXXXXX)
        apk add --no-cache \
            luci-app-dockerman luci-i18n-dockerman-zh-cn \
            > "$__lt" 2>&1
        cat "$__lt" | logger -t "$_LT"; rm -f "$__lt"
        log "luci-app-dockerman 安装完成"
    else
        log "Flash <25MB，跳过 dockerman LuCI"
    fi
fi

# ══ AdGuardHome 部署 ═══════════════════════════════════════════════
_AGH_FAIL=0
log "--- AdGuardHome 部署开始 ---"

__atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
__abin="$_USB/adguardhome-bin"
__aconf="$_USB/AdGuardHome/config"
__adata="$_USB/AdGuardHome/data"
mkdir -p "$__abin" "$__aconf" "$__adata"

if [ -f "$__atgz" ] && ! tar -tzf "$__atgz" >/dev/null 2>&1; then
    log "AGH 缓存损坏，删除后重新下载"
    rm -f "$__atgz"
fi
if [ ! -f "$__atgz" ]; then
    _download "$_AGH_URL" "$__atgz" "AdGuardHome" \
        || { _AGH_FAIL=1; rm -f "$__atgz"; }
fi

if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
    log "解压 AdGuardHome..."
    tar -xzf "$__atgz" -C "$__abin" --strip-components=1 2>/dev/null
    if [ -d "$__abin/AdGuardHome" ] && [ -f "$__abin/AdGuardHome/AdGuardHome" ]; then
        mv "$__abin/AdGuardHome/AdGuardHome" "$__abin/AdGuardHome_bin"
        rm -rf "$__abin/AdGuardHome"
        mv "$__abin/AdGuardHome_bin" "$__abin/AdGuardHome"
    fi
    if [ ! -f "$__abin/AdGuardHome" ]; then
        log "AdGuardHome 解压失败，删除缓存"
        rm -f "$__atgz"; _AGH_FAIL=1
    else
        chmod +x "$__abin/AdGuardHome"
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null
        log "symlink: /usr/bin/AdGuardHome"
    fi
fi

if [ "$_AGH_FAIL" -eq 0 ]; then
    /etc/init.d/adguardhome stop 2>/dev/null || true

    if [ ! -f "$__aconf/AdGuardHome.yaml" ] \
    && [ -f "/etc/adguardhome/AdGuardHome.yaml" ]; then
        cp -a /etc/adguardhome/. "$__aconf/" 2>/dev/null
        chown -R root:root "$__aconf" 2>/dev/null
        chmod 644 "$__aconf/AdGuardHome.yaml" 2>/dev/null
        log "AGH 配置已迁移至 U 盘（首次）"
    else
        log "AGH 配置已存在或无源配置，不覆盖"
    fi
    if [ -z "$(ls -A "$__adata" 2>/dev/null)" ] \
    && [ -d "/var/lib/adguardhome" ] \
    && [ -n "$(ls -A /var/lib/adguardhome 2>/dev/null)" ]; then
        cp -a /var/lib/adguardhome/. "$__adata/" 2>/dev/null
        chown -R root:root "$__adata" 2>/dev/null
        log "AGH 数据已迁移至 U 盘（首次）"
    fi

    # Fix #2：无配置文件时不传 --config，进入 setup 模式（:3000）
    cat > /etc/init.d/adguardhome << 'AINITEOF'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -z "$_mp" ] || [ ! -f "$_mp/adguardhome-bin/AdGuardHome" ] && {
        uci set dhcp.@dnsmasq[0].port='53' 2>/dev/null
        uci commit dhcp 2>/dev/null
        /etc/init.d/dnsmasq restart >/dev/null 2>&1
        return 1
    }
    _config="$_mp/AdGuardHome/config/AdGuardHome.yaml"
    if [ -f "$_config" ]; then
        # 有配置：AGH 接管 DNS，dnsmasq 退让（保留 DHCP）
        uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
        uci commit dhcp 2>/dev/null
        /etc/init.d/dnsmasq restart >/dev/null 2>&1
        procd_open_instance
        procd_set_param command \
            "$_mp/adguardhome-bin/AdGuardHome" \
            --config "$_config" \
            --work-dir "$_mp/AdGuardHome/data" \
            --no-check-update
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_set_param respawn 3600 5 0
        procd_close_instance
    else
        # 无配置：setup 模式（:3000），dnsmasq 继续服务 DNS
        procd_open_instance
        procd_set_param command \
            "$_mp/adguardhome-bin/AdGuardHome" \
            --work-dir "$_mp/AdGuardHome/data" \
            --no-check-update
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_set_param respawn 3600 5 0
