[ -z "$__usb_mp" ] && exit 0
_is_mounted "$__usb_mp" && exit 0

logger -t "usb-protect" "部署 U 盘 ($__usb_mp) 已拔出，停止重型服务..."

# 优雅停止 Docker 容器
if command -v docker >/dev/null 2>&1; then
    __cids=$(docker ps -q 2>/dev/null)
    [ -n "$__cids" ] && docker stop $__cids 2>/dev/null || true
    sleep 2
fi
# stop_service 内部会恢复 dnsmasq DNS 端口
/etc/init.d/dockerd     stop 2>/dev/null || true
/etc/init.d/adguardhome stop 2>/dev/null || true

logger -t "usb-protect" "服务已停止（dnsmasq DNS 已恢复），重新插入 U 盘后将自动恢复"
PROTECTEOF
chmod +x /etc/hotplug.d/block/97-usb-protect

# ══════════════════════════════════════════════════════════════
# 模块 H：360v6-uninstall（卸载脚本）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-uninstall << 'UNINSTALLEOF'
#!/bin/sh
echo "=== 360 V6 卸载 ==="
echo ""
echo "将执行以下操作："
echo "  1. 停止 Docker / AdGuardHome 服务"
echo "  2. 恢复 dnsmasq DNS（端口 53）"
echo "  3. 删除 init.d 脚本、symlink、配置文件"
echo "  4. 删除状态文件、hotplug、cron 条目"
echo "  5. 删除本脚本及 360v6-status / 360v6-health"
echo ""
echo "U 盘上的数据（docker-data、AdGuardHome 配置/数据）将保留"
echo ""

__yes=0
for _a in "$@"; do [ "$_a" = "--yes" ] && __yes=1; done
if [ "$__yes" -eq 0 ]; then
    printf "确认卸载？[y/N] "
    read _c
    [ "$_c" = "y" ] || [ "$_c" = "Y" ] || { echo "已取消"; exit 0; }
fi

echo ""
echo "停止服务..."
/etc/init.d/dockerd     stop 2>/dev/null || true
/etc/init.d/dockerd     disable 2>/dev/null || true
/etc/init.d/adguardhome stop 2>/dev/null || true
/etc/init.d/adguardhome disable 2>/dev/null || true

echo "恢复 dnsmasq DNS..."
uci set dhcp.@dnsmasq[0].port='53' 2>/dev/null
uci commit dhcp 2>/dev/null
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true

echo "删除 init.d 脚本..."
rm -f /etc/init.d/dockerd /etc/init.d/adguardhome

echo "删除 symlink..."
for _b in docker dockerd docker-init docker-proxy containerd \
          containerd-shim-runc-v2 ctr runc AdGuardHome; do
    rm -f "/usr/bin/$_b"
done

echo "删除配置..."
rm -f /etc/docker/daemon.json
rm -rf /etc/docker

echo "删除状态文件..."
rm -f /etc/install-extras-done /etc/install-usb-done
rm -f /etc/install-usb-mount
rm -rf /etc/install-state

echo "删除脚本..."
rm -f /usr/lib/install-extras/run.sh
rm -f /usr/lib/install-extras/install-usb.sh
rmdir /usr/lib/install-extras 2>/dev/null || true
rm -f /usr/bin/360v6-status
rm -f /usr/bin/360v6-health

echo "删除 hotplug..."
rm -f /etc/hotplug.d/iface/96-install-extras
rm -f /etc/hotplug.d/block/96-install-usb
rm -f /etc/hotplug.d/block/97-usb-protect

echo "清理 cron..."
sed -i '/install-usb.sh/d' /etc/crontabs/root 2>/dev/null
sed -i '/agh-log-clean/d'   /etc/crontabs/root 2>/dev/null
/etc/init.d/cron restart 2>/dev/null || true

echo "删除 profile.d..."
rm -f /etc/profile.d/docker-usb.sh 2>/dev/null

echo ""
echo "=== 卸载完成 ==="
echo "U 盘上的 docker-data/ 和 AdGuardHome/ 数据已保留"
echo "如需完全清理，请手动删除 U 盘目录"
echo ""
echo "删除本脚本: rm -f /usr/bin/360v6-uninstall"
UNINSTALLEOF
chmod +x /usr/bin/360v6-uninstall

# ══════════════════════════════════════════════════════════════
# 完成
# ══════════════════════════════════════════════════════════════
logger -t "install-extras" "v11 哨兵安装完成，等待 WAN 上线触发"
logger -t "install-extras" "执行 '360v6-status' 查看状态"
exit 0
